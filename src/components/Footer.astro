---
const currentYear = new Date().getFullYear();
---

<footer class="container py-4 mt-3">
  <div class="row align-items-center text-center text-md-start">
    <!-- Firma a la izquierda -->
    <div class="col-md-6 mb-3 mb-md-0 d-flex justify-content-center justify-content-md-start align-items-center">
      <span class="text-body-secondary">© 2024 - <span id="anioActual">{currentYear}</span>,</span>
      <span id="miFirma" class="ms-2" style="font-size: 26px">Daniel Bautista Pradilla.</span>
    </div>

    <!-- Enlaces a la derecha -->
    <div class="col-md-6 d-flex justify-content-center justify-content-md-end gap-3">
      <a
        class="text-body-secondary"
        href="https://github.com/Danielbp019/"
        target="_blank"
        aria-label="Perfil de GitHub"
      >
        <i class="bi bi-github" style="font-size: 1.5rem"></i>
      </a>
      <a
        class="text-body-secondary"
        href="https://getbootstrap.com/"
        target="_blank"
        aria-label="Sitio oficial de Bootstrap"
      >
        <i class="bi bi-bootstrap-fill" style="font-size: 1.5rem"></i>
      </a>
      <a class="text-body-secondary" href="#top" aria-label="Ir arriba">
        <i class="bi bi-arrow-up-circle-fill" style="font-size: 1.5rem"></i>
      </a>
    </div>
  </div>
</footer>
