---
import "bootstrap/dist/css/bootstrap.min.css";
import "bootstrap-icons/font/bootstrap-icons.css";
import "../assets/styles/consumo.css";
import { fade, ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
}

const { title = "Timber-Tec" } = Astro.props;
---

<!doctype html>
<html lang="es" data-bs-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Daniel Bautista Pradilla" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <script>
      // @ts-ignore
      import * as bootstrap from "bootstrap/dist/js/bootstrap.bundle.min.js";
      // @ts-ignore
      window.bootstrap = bootstrap;
    </script>
  </head>
  <body id="contenido" transition:animate={fade({ duration: "0.5s" })}>
    <slot />
  </body>
</html>
